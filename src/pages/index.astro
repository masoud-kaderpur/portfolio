---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <title>{SITE_TITLE}</title>
    </head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Masoud Kaderpur - Software Engineer Student</h1>
				<p>Designing and building systems. Focused on reliability, observability, and improving developer experience.</p>
			</section>

			<section class="featured">
				<h2>Featured Work</h2>
				<div class="grid">
					<a class="card" href="/projects">Explore my projects →</a>
				</div>
			</section>

			<section class="education">
				<h2>Education</h2>
                <p>B.Sc. Computer Science — Technical University Vienna. Courses: Algorithms and Datastructures, Software Engineering, Linear Algebra, Database Systems</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
